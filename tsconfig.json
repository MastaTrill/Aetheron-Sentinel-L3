{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["./hardhat.config.ts", "./scripts", "./test", "./src"],
  "exclude": ["generated", "generated/**", "node_modules"]
}
