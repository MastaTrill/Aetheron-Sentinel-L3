SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=YOUR_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# Deployment owner and control-plane addresses
SENTINEL_OWNER=
RELAYER_ADDRESSES=
CALLER_ADDRESSES=
MONITOR_ADDRESSES=
REPORTER_ADDRESSES=
SECURITY_REPORTER_ADDRESSES=

# Monitoring and bridge setup
TRACKED_CHAIN_IDS=11155111
BRIDGE_TOKEN_ADDRESSES=
CHAIN_LIMITS=11155111:1000000

# Yield and staking setup
YIELD_TOKEN_ADDRESS=
STAKING_TOKEN_ADDRESS=
REWARD_TOKEN_ADDRESS=
LP_TOKEN_ADDRESS=
REWARD_PER_SECOND=0

# Interceptor setup
ANOMALY_THRESHOLD=10
TVL_THRESHOLD_ETH=1000
AUTONOMOUS_MODE=true

# Governance (SentinelTimelock + SentinelGovernance)
# TIMELOCK_MIN_DELAY: minimum execution delay in seconds (default: 172800 = 2 days)
TIMELOCK_MIN_DELAY=172800
# TIMELOCK_PROPOSERS: comma-separated addresses that can propose (defaults to deployer)
TIMELOCK_PROPOSERS=
# TIMELOCK_EXECUTORS: comma-separated addresses that can execute (default: address(0) = anyone)
TIMELOCK_EXECUTORS=
# TIMELOCK_ADMIN: who holds TIMELOCK_ADMIN_ROLE (defaults to SENTINEL_OWNER)
TIMELOCK_ADMIN=

# Post-deploy: paste the JSON address map printed by deploy.js for verify/subgraph scripts
DEPLOYED_ADDRESSES=
# Block number at which the first contract was deployed (for subgraph startBlock)
START_BLOCK=0
# Sepolia Etherscan/subgraph base URL (for site config generation)
EXPLORER_BASE_URL=https://sepolia.etherscan.io/address
