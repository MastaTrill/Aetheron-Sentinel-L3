{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["test/**/*.js"],
      "env": {
        "mocha": true
      },
      "rules": {
        "no-unused-vars": "off",
        "no-undef": "off",
        "no-redeclare": "off"
      }
    }
  ],
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-empty": "warn",
    "no-useless-escape": "warn"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/generated/**",
    "**/artifacts/**",
    "**/cache/**",
    "**/dist/**",
    "**/coverage/**",
    "**/build/**",
    "**/*.generated.*",
    "**/imports/**",
    "**/site/**",
    "**/src/**"
  ]
}
