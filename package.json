{
  "name": "aetheron-sentinel-l3",
  "version": "1.0.0",
  "description": "Autonomous Interceptor for blockchain bridge security - blocks liquidity drain attacks in 14ms",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy-local.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:security": "hardhat run scripts/deploy-security-modules.ts --network localhost",
    "deploy:security:sepolia": "hardhat run scripts/deploy-security-modules.ts --network sepolia",
    "deploy:basegork": "hardhat run scripts/deploy.ts --network baseGork",
    "deploy:amoy": "hardhat run scripts/deploy-local.ts --network amoy",
    "deploy:full": "hardhat run scripts/deploy-local.ts --network localhost && hardhat run scripts/deploy-security-modules.ts --network localhost",
    "render:subgraph:sepolia": "python3 scripts/render_subgraph_manifest.py",
    "node": "hardhat node",
    "clean": "hardhat clean",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol' 'test/**/*.ts' 'scripts/**/*.ts'"
  },
  "keywords": [
    "ethereum",
    "blockchain",
    "bridge",
    "security",
    "defi",
    "sentinel",
    "liquidity-protection"
  ],
  "author": "Aetheron Labs",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.0",
    "dotenv": "^16.3.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.0.0",
    "prettier-plugin-solidity": "^1.1.0",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@account-abstraction/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "ethers": "^6.9.0"
  }
}
