{
  "name": "aetheron-sentinel-l3",
  "version": "1.0.0",
  "description": "Autonomous Sentinel L3 Node Environment",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "hardhat test test/smoke.test.js test/AetheronBridge.test.js",
    "mocha": "hardhat test test/smoke.test.js test/AetheronBridge.test.js",
    "test:gas": "npm run compile && node scripts/gas-analysis.js",
    "test:coverage": "hardhat coverage",
    "compile": "node scripts/compile-contracts.cjs",
    "deploy": "hardhat run scripts/deploy.cjs",
    "deploy:mainnet": "hardhat run scripts/deploy.cjs --network mainnet",
    "deploy:polygon": "hardhat run scripts/deploy.cjs --network polygon",
    "deploy:base": "hardhat run scripts/deploy.cjs --network base",
    "deploy:arbitrum": "hardhat run scripts/deploy.cjs --network arbitrum",
    "setup:ownership": "hardhat run scripts/setup-ownership.cjs",
    "deploy:verify": "npm run compile && node scripts/deployment-verification.js",
    "lint": "eslint hardhat.config.js scripts/ test/ --config .eslintrc.json --max-warnings 20",
    "lint:fix": "eslint hardhat.config.js scripts/ test/ --config .eslintrc.json --fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "security:audit": "npm audit --audit-level=moderate",
    "export:all-abis": "node scripts/export-abis.js",
    "add-liquidity": "hardhat run scripts/add-liquidity.js",
    "codegen": "graph codegen",
    "build": "graph build"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@uniswap/v4-core": "^1.0.2",
    "dotenv": "^16.4.5",
    "fp-ts": "^2.16.11",
    "io-ts": "^2.2.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@chainlink/contracts": "^0.4.0",
    "@chainlink/contracts-ccip": "^1.6.4",
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.26.0",
    "@layerzerolabs/solidity-examples": "^1.1.0",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.7",
    "@nomicfoundation/hardhat-ethers": "^4.0.10",
    "@nomicfoundation/hardhat-mocha": "^3.0.18",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "5.2.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": "^9.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "chai": "^4.5.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^2.1.1",
    "ethers": "^6.10.0",
    "hardhat": "^3.4.4",
    "prettier": "^3.2.5",
    "ts-node": "^10.0.0",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@openzeppelin/contracts": "5.2.0",
    "@openzeppelin/contracts-upgradeable": "5.2.0",
    "@openzeppelin-3/contracts": "npm:@openzeppelin/contracts@^4.9.6",
    "@openzeppelin/contracts-4.7.3": "npm:@openzeppelin/contracts@^4.9.6",
    "@openzeppelin/contracts-4.8.3": "npm:@openzeppelin/contracts@^4.9.6",
    "cross-spawn": "^7.0.6",
    "semver": "^7.7.2",
    "qs": "^6.14.1",
    "yaml": "^2.8.3",
    "ejs": "^3.1.10",
    "tough-cookie": "^4.1.4",
    "elliptic": "^6.6.1",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "form-data": "^2.5.4",
    "cookie": "^0.7.2",
    "immutable": "^5.1.5",
    "axios": "^1.9.0",
    "js-yaml": "^4.1.1",
    "undici": ">=7.24.0",
    "glob": "^11.0.4",
    "eth-gas-reporter": "^0.2.27",
    "debug": "^4.3.7",
    "diff": "^5.2.1",
    "serialize-javascript": "^7.0.5",
    "uuid": "^14.0.0",
    "mocha": "^11.7.5",
    "hardhat-gas-reporter": "^2.3.0"
  }
}
