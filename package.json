{
  "name": "aetheron-sentinel-l3",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:local": "hardhat run scripts/deploy.cjs --network hardhat",
    "deploy:testnet": "hardhat run scripts/deploy.cjs --network sepolia",
    "deploy:testnet:full": "bash scripts/deploy-testnet.sh",
    "deploy:sepolia": "hardhat run scripts/deploy.cjs --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.cjs --network mainnet",
    "verify:testnet": "hardhat run scripts/verify.cjs --network sepolia",
    "verify:mainnet": "hardhat run scripts/verify.cjs --network mainnet",
    "export:abis": "node scripts/export-abis.cjs",
    "update:subgraph": "node scripts/update-subgraph.cjs",
    "export:site-config": "node scripts/export-site-config.cjs",
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy:subgraph": "graph deploy --node https://api.thegraph.com/deploy/ aetheron-sentinel-l3",
    "create-local": "graph create --node http://localhost:8020/ aetheron-sentinel-l3",
    "remove-local": "graph remove --node http://localhost:8020/ aetheron-sentinel-l3",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 aetheron-sentinel-l3"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "0.98.1",
    "@graphprotocol/graph-ts": "0.32.0",
    "@openzeppelin/contracts": "^4.9.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.4",
    "dotenv": "^16.4.5",
    "hardhat": "^3.4.0",
    "matchstick-as": "0.6.0"
  }
}
