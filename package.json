{
  "name": "aetheron-sentinel-l3",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "deploy:local": "hardhat run scripts/deploy.cjs --network hardhat",
    "deploy:testnet": "hardhat run scripts/deploy.cjs --network sepolia",
    "deploy:testnet:full": "bash scripts/deploy-testnet.sh",
    "deploy:sepolia": "hardhat run scripts/deploy.cjs --network sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.cjs --network mainnet",
    "redeploy:coreloop": "node scripts/redeploy-coreloop.cjs --network sepolia",
    "verify:testnet": "node scripts/verify.cjs --network sepolia",
    "setup:ownership": "node scripts/setup-ownership.cjs --network sepolia",
    "verify:mainnet": "node scripts/verify.cjs --network mainnet",
    "deploy:hoodi": "hardhat run scripts/deploy.cjs --network hoodi",
    "deploy:baseSepolia": "hardhat run scripts/deploy.cjs --network baseSepolia",
    "verify:hoodi": "node scripts/verify.cjs --network hoodi",
    "verify:baseSepolia": "node scripts/verify.cjs --network baseSepolia",
    "export:abis": "node scripts/export-abis.cjs",
    "update:subgraph": "node scripts/update-subgraph.cjs",
    "export:site-config": "node scripts/export-site-config.cjs",
    "codegen": "npx -y @graphprotocol/graph-cli@0.98.1 codegen",
    "build": "npx -y @graphprotocol/graph-cli@0.98.1 build",
    "deploy:subgraph": "npx -y @graphprotocol/graph-cli@0.98.1 deploy --node https://api.thegraph.com/deploy/ aetheron-sentinel-l3",
    "create-local": "npx -y @graphprotocol/graph-cli@0.98.1 create --node http://localhost:8020/ aetheron-sentinel-l3",
    "remove-local": "npx -y @graphprotocol/graph-cli@0.98.1 remove --node http://localhost:8020/ aetheron-sentinel-l3",
    "deploy-local": "npx -y @graphprotocol/graph-cli@0.98.1 deploy --node http://localhost:8020/ --ipfs http://localhost:5001 aetheron-sentinel-l3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  },
  "devDependencies": {
    "@graphprotocol/graph-ts": "0.32.0",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.4",
    "dotenv": "^16.4.5",
    "hardhat": "^3.4.0",
    "matchstick-as": "0.6.0"
  },
  "overrides": {
    "@graphprotocol/graph-cli": {
      "glob": "10.4.5",
      "yaml": "2.8.3",
      "js-yaml": "4.1.1",
      "immutable": "5.1.5",
      "semver": "7.7.4",
      "undici": "7.24.0"
    },
    "gluegun": {
      "cross-spawn": "7.0.6",
      "ejs": "3.1.10",
      "semver": "7.7.4"
    },
    "mocha": {
      "diff": "9.0.0",
      "serialize-javascript": "7.0.5"
    }
  }
}
